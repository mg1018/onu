{
  "name": "onyoo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3004",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "db:generate": "dotenv -e .env.local -- drizzle-kit generate",
    "db:push": "dotenv -e .env.local -- drizzle-kit push",
    "db:studio": "dotenv -e .env.local -- drizzle-kit studio",
    "db:seed": "dotenv -e .env.development.local -e .env.local -- tsx scripts/seed.ts",
    "heygen:check": "dotenv -e .env.local -- tsx scripts/heygen-check.ts",
    "drive:check": "dotenv -e .env.development.local -e .env.local -- tsx scripts/drive-check.ts",
    "drive:oauth-init": "dotenv -e .env.local -- tsx scripts/drive-oauth-init.ts",
    "workflow:web": "workflow web",
    "workflow:health": "workflow health"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.72",
    "@neondatabase/serverless": "^1.1.0",
    "@vercel/blob": "^2.3.3",
    "@workflow/ai": "^4.1.2",
    "@workflow/next": "^4.0.5",
    "ai": "^6.0.168",
    "drizzle-orm": "^0.45.2",
    "googleapis": "^171.4.0",
    "nanoid": "^5.1.9",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.12.2",
    "workflow": "^4.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
